    ").size().reset_index(name='count')\n",
    "ct_yearly = ct_yearly[ct_yearly['year_added'].between(2015, 2021)]\n",
    "\n",
    "fig = px.line(\n",
    "    ct_yearly, x='year_added', y='count', color='primary_country',\n",
    "    markers=True,\n",
    "    title='📈 Yearly Content Additions — Top 5 Countries (Interactive)',\n",
    "    labels={'year_added': 'Year', 'count': 'Titles Added', 'primary_country': 'Country'},\n",
    "    color_discrete_sequence=px.colors.qualitative.Plotly\n",
    ")\n",
    "fig.update_layout(\n",
    "    xaxis=dict(dtick=1),\n",
    "    legend_title_text='Country',\n",
    "    hovermode='x unified',\n",
    "    template='plotly_dark'\n",
    ")\n",
    "fig.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Interactive bubble chart — Rating vs Avg Duration, colored by type\n",
    "rate_dur = df.groupby(['rating', 'type']).agg(\n",
    "    avg_dur=('duration_value', 'mean'),\n",
    "    count=('show_id', 'count')\n",
    ").reset_index()\n",
    "\n",
    "fig2 = px.scatter(\n",
    "    rate_dur, x='rating', y='avg_dur', size='count', color='type',\n",
    "    hover_name='rating', size_max=60,\n",
    "    title='🫧 Rating vs Avg Duration — Bubble Size = Number of Titles',\n",
    "    labels={'avg_dur': 'Avg Duration', 'rating': 'Rating'},\n",
    "    color_discrete_map={'Movie': '#E50914', 'TV Show': '#00B4D8'},\n",
    "    template='plotly_dark'\n",
    ")\n",
    "fig2.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 6. Feature Engineering"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- 6.1 Ratio & Math Features ---\n",
    "\n",
    "# How old is the content relative to when it was added?\n",
    "df['age_when_added'] = df['year_added'] - df['release_year']    # time-to-platform\n",
    "\n",
    "# Log-transform duration (reduces right-skew for ML models)\n",
    "df['log_duration'] = np.log1p(df['duration_value'])\n",
    "\n",
    "print('age_when_added stats:')\n",
    "print(df['age_when_added'].describe().round(2))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- 6.2 Binning ---\n",
    "\n",
    "# Era of release\n",
    "df['era'] = pd.cut(\n",
    "    df['release_year'],\n",
    "    bins=[1900, 1980, 2000, 2010, 2016, 2025],\n",
    "    labels=['Classic', '80s-90s', '2000s', '2010s', 'Recent']\n",
    ")\n",
    "\n",
    "# Duration bucket (movies only)\n",
    "movie_mask = df['type'] == 'Movie'\n",
    "df.loc[movie_mask, 'duration_bucket'] = pd.cut(\n",
    "    df.loc[movie_mask, 'duration_value'],\n",
    "    bins=[0, 60, 90, 120, 180, 9999],\n",
    "    labels=['Short', 'Standard-', 'Standard+', 'Long', 'Epic']\n",
    ")\n",
    "\n",
    "print(df['era'].value_counts())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- 6.3 Date/Time Features ---\n",
    "df['month_added']   = df['date_added'].dt.month\n",
    "df['quarter_added'] = df['date_added'].dt.quarter\n",
    "df['is_q4_release'] = (df['quarter_added'] == 4).astype(int)   # Q4 = holiday season\n",
    "\n",
    "q4_pct = df['is_q4_release'].mean() * 100\n",
    "print(f'{q4_pct:.1f}% of titles were added in Q4 — Netflix likely pushes content for holiday viewing.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- 6.4 Count / Aggregation Features ---\n",
    "\n",
    "# Number of genres each title belongs to\n",
    "df['num_genres'] = df['listed_in'].str.count(',') + 1\n",
    "\n",
    "# Number of cast members listed\n",
    "df['cast_size'] = df['cast'].apply(\n",
    "    lambda x: len(x.split(',')) if x != 'Unknown' else 0\n",
    ")\n",
    "\n",
    "# Country count (co-productions)\n",
    "df['num_countries'] = df['country'].apply(\n",
    "    lambda x: len(x.split(',')) if x != 'Unknown' else 1\n",
    ")\n",
    "\n",
    "# Director popularity: how many titles has this director made on Netflix?\n",
    "dir_counts = df[df['director'] != 'Unknown']['director'].value_counts()\n",
    "df['director_title_count'] = df['director'].map(dir_counts).fillna(0)\n",
    "\n",
    "print(df[['num_genres','cast_size','num_countries','director_title_count']].describe().round(2))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- 6.5 Feature Combination ---\n",
    "# \"Prolific co-production\" flag: many countries AND many genres\n",
    "df['is_collab_title'] = ((df['num_countries'] > 1) & (df['num_genres'] > 2)).astype(int)\n",
    "\n",
    "# Encode era and duration_bucket for ML use\n",
    "df['era_enc'] = df['era'].cat.codes          # NaN → -1 is OK for this analysis\n",
    "df['dur_bucket_enc'] = df['duration_bucket'].cat.codes if 'duration_bucket' in df else 0\n",
    "\n",
    "print('New engineered features:', ['age_when_added','log_duration','era','month_added',\n",
    "      'is_q4_release','num_genres','cast_size','num_countries','director_title_count','is_collab_title'])"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 7. Feature Selection — Mutual Information"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Target: predict content type (Movie vs TV Show) → binary after encoding\n",
    "feature_cols = [\n",
    "    'release_year', 'duration_value', 'log_duration',\n",
    "    'rating_enc', 'age_when_added', 'num_genres',\n",
    "    'cast_size', 'num_countries', 'director_title_count',\n",
    "    'month_added', 'is_q4_release', 'is_collab_title', 'era_enc'\n",
    "]\n",
    "\n",
    "X = df[feature_cols].fillna(0)\n",
    "y = df['type_enc']\n",
    "\n",
    "mi_scores = mutual_info_classif(X, y, random_state=RANDOM_SEED)\n",
    "mi_series = pd.Series(mi_scores, index=feature_cols).sort_values(ascending=False)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 5))\n",
    "bars = ax.barh(mi_series.index, mi_series.values,\n",
    "               color=sns.color_palette('Reds_r', len(mi_series)))\n",
    "ax.set_title('Mutual Information Scores — Predicting Content Type', fontsize=13, fontweight='bold')\n",
    "ax.set_xlabel('MI Score')\n",
    "ax.invert_yaxis()\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print('Top 3 most informative features:')\n",
    "print(mi_series.head(3))"
   ]
