    "plt.xticks(rotation=0)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 5.7 Scatter Plot — Release Year vs Duration (Movies)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "movies = df[(df['type'] == 'Movie') & (df['release_year'] >= 1970)].copy()\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(11, 5))\n",
    "sc = ax.scatter(\n",
    "    movies['release_year'], movies['duration_value'],\n",
    "    alpha=0.3, s=15, c=movies['release_year'],\n",
    "    cmap='Reds', edgecolors='none'\n",
    ")\n",
    "plt.colorbar(sc, ax=ax, label='Release Year')\n",
    "ax.set_title('Movie: Release Year vs Duration', fontsize=14, fontweight='bold')\n",
    "ax.set_xlabel('Release Year')\n",
    "ax.set_ylabel('Duration (minutes)')\n",
    "ax.set_ylim(0, 250)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "corr = movies['release_year'].corr(movies['duration_value'])\n",
    "print(f'Pearson correlation (year vs duration): {corr:.3f} — near zero, release year does not predict runtime.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 5.8 Bubble Chart — Top Genres: Count & Avg Duration"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Explode multi-genre column\n",
    "genres = df.assign(genre=df['listed_in'].str.split(', ')).explode('genre')\n",
    "genre_stats = genres.groupby('genre').agg(\n",
    "    count=('show_id', 'count'),\n",
    "    avg_duration=('duration_value', 'mean')\n",
    ").reset_index()\n",
    "genre_stats = genre_stats.sort_values('count', ascending=False).head(15)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(12, 6))\n",
    "scatter = ax.scatter(\n",
    "    genre_stats['count'],\n",
    "    genre_stats['avg_duration'],\n",
    "    s=genre_stats['count'] * 0.3,\n",
    "    c=range(len(genre_stats)),\n",
    "    cmap='tab20', alpha=0.75, edgecolors='grey', linewidth=0.5\n",
    ")\n",
    "for _, row in genre_stats.iterrows():\n",
    "    ax.annotate(row['genre'], (row['count'], row['avg_duration']),\n",
    "                fontsize=7.5, ha='center', va='bottom', alpha=0.85)\n",
    "ax.set_title('Top 15 Genres — Title Count vs Avg Duration (bubble size ∝ count)',\n",
    "             fontsize=13, fontweight='bold')\n",
    "ax.set_xlabel('Number of Titles')\n",
    "ax.set_ylabel('Average Duration')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 5.9 Error Bar Chart — Mean Duration per Rating (with 95% CI)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "movie_ratings = df[(df['type'] == 'Movie') & (df['rating'].isin(top_ratings))].copy()\n",
    "rating_agg = movie_ratings.groupby('rating')['duration_value'].agg(['mean','std','count']).reset_index()\n",
    "# 95% CI = 1.96 * std / sqrt(n)\n",
    "rating_agg['ci95'] = 1.96 * rating_agg['std'] / np.sqrt(rating_agg['count'])\n",
    "rating_agg = rating_agg.sort_values('mean', ascending=False)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(9, 5))\n",
    "ax.bar(rating_agg['rating'], rating_agg['mean'],\n",
    "       yerr=rating_agg['ci95'], capsize=6,\n",
    "       color=sns.color_palette('coolwarm', len(rating_agg)),\n",
    "       alpha=0.85, edgecolor='white', error_kw=dict(elinewidth=1.5, ecolor='dimgrey'))\n",
    "ax.set_title('Mean Movie Duration by Rating (95% CI error bars)', fontsize=13, fontweight='bold')\n",
    "ax.set_xlabel('Rating')\n",
    "ax.set_ylabel('Avg Duration (minutes)')\n",
    "ax.set_ylim(0, rating_agg['mean'].max() + 20)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 5.10 Interactive Chart (Plotly) — Content Growth by Country Over Time"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Interactive multi-line: top 5 countries' yearly additions\n",
    "top5 = country_counts.head(5).index.tolist()\n",
    "ct_yearly = df[df['primary_country'].isin(top5)].groupby(\n",
